{
  "manifest_version": 3,
  "name": "EcoOffset",
  "version": "1.0.0",
  "description": "EcoOffset - Make sustainable choices while shopping online",
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "EcoOffset"
  },
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.ca/*",
    "*://*.ebay.com/*",
    "*://*.ebay.ca/*",
    "*://*.walmart.com/*",
    "*://*.walmart.ca/*",
    "*://*.target.com/*",
    "*://*.bestbuy.com/*",
    "*://*.bestbuy.ca/*",
    "*://*.costco.com/*",
    "*://*.costco.ca/*",
    "*://*.aliexpress.com/*",
    "*://*.temu.com/*",
    "*://*.shein.com/*",
    "*://*.wayfair.ca/*",
    "*://*.ikea.com/*",
    "*://*.homedepot.ca/*",
    "*://*.lowes.com/*",
    "*://*.etsy.com/*",
    "*://*.alibaba.com/*",
    "*://*.newegg.ca/*",
    "*://*.apple.com/*",
    "*://*.bhphotovideo.com/*",
    "*://*.microcenter.com/*",
    "http://localhost:11434/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.ca/*",
        "*://*.ebay.com/*",
        "*://*.ebay.ca/*",
        "*://*.walmart.com/*",
        "*://*.walmart.ca/*",
        "*://*.target.com/*",
        "*://*.bestbuy.com/*",
        "*://*.bestbuy.ca/*",
        "*://*.costco.com/*",
        "*://*.costco.ca/*",
        "*://*.aliexpress.com/*",
        "*://*.temu.com/*",
        "*://*.shein.com/*",
        "*://*.wayfair.ca/*",
        "*://*.ikea.com/*",
        "*://*.homedepot.ca/*",
        "*://*.lowes.com/*",
        "*://*.etsy.com/*",
        "*://*.alibaba.com/*",
        "*://*.newegg.ca/*",
        "*://*.apple.com/*",
        "*://*.bhphotovideo.com/*",
        "*://*.microcenter.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
